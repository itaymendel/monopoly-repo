{
  "name": "monopoly-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "cli",
    "site"
  ],
  "scripts": {
    "dev": "cd cli && bun run dev",
    "build": "cd cli && bun run build",
    "build:npm": "cd cli && bun run build:npm",
    "test": "cd cli && bun test",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "site:preview": "cd site && bun run preview",
    "site:check": "cd site && bun run check"
  }
}
